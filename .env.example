# Frontend (Vercel)
# Set this in Vercel Project Settings -> Environment Variables
VITE_API_URL=https://your-render-service.onrender.com/api

# Backend (Render)
# Set these in Render Service -> Environment
PORT=3001
FRONTEND_URL=https://your-vercel-project.vercel.app
JWT_SECRET=replace_with_a_long_random_secret
DB_PATH=/var/data/camap.db

# YouTube info page (/info)
# 1) Enable YouTube Data API v3 in Google Cloud
# 2) Create API key and paste below
YOUTUBE_API_KEY=replace_with_youtube_api_key

# Configure channel by ID (preferred) or handle/url
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_HANDLE=@CaBeoAudio
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@CaBeoAudio
